{
  "name": "@jgleman/color-box",
  "version": "2.0.0",
  "description": "Another JavaScript/TypeScript Color Utility Library",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean:dist": "rimraf dist",
    "test": "jest",
    "build": "npm run clean:dist && npm run test && pkgroll --target-es2020 --minify",
    "watch": "pkgroll --watch --target-es2020 --minify",
    "docs:generate": "typedoc",
    "docs:dev": "vitepress dev docs",
    "docs:build": "typedoc && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgleman/color-box.git"
  },
  "keywords": [
    "typescript",
    "javascript",
    "color",
    "colors",
    "hex",
    "rgb",
    "hsl",
    "css"
  ],
  "author": "Jason Gleman",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jgleman/color-box/issues"
  },
  "homepage": "https://github.com/jgleman/color-box#readme",
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.2.0",
    "pkgroll": "^2.17.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4"
  }
}
