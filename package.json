{
  "name": "@jgleman/color-box",
  "version": "1.0.0",
  "description": "Another JavaScript/TypeScript Color Utility Library",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "clean:dist": "rimraf dist",
    "test": "jest",
    "build": "npm run clean:dist && npm run test && pkgroll --target-es2020 --minify && npm run docs",
    "watch": "pkgroll --watch --target-es2020 --minify",
    "docs": "typedoc --out docs src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgleman/color-box.git"
  },
  "keywords": [
    "typescript",
    "javascript",
    "color",
    "colors",
    "hex",
    "rgb",
    "hsl",
    "css"
  ],
  "author": "Jason Gleman",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jgleman/color-box/issues"
  },
  "homepage": "https://github.com/jgleman/color-box#readme",
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@jest/globals": "^30.2.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.2.0",
    "pkgroll": "^2.17.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.13",
    "typescript": "^5.9.3"
  }
}
